  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Étape 3 : Monter Google Drive ─────────────────────────────\n",
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "# ⚠️ Adaptez ce chemin : c'est le dossier Drive où sont vos CSV BAAC\n",
    "DATA_DIR = '/content/drive/MyDrive/AccidentsFrance/'\n",
    "\n",
    "# Vérification des fichiers disponibles\n",
    "import os\n",
    "print(f'\\n📁 Fichiers trouvés dans {DATA_DIR} :')\n",
    "try:\n",
    "    files = sorted([f for f in os.listdir(DATA_DIR) if f.endswith('.csv')])\n",
    "    baac_files = [f for f in files if any(k in f for k in ['caract','usager','vehicule','lieu'])]\n",
    "    other_files = [f for f in files if f not in baac_files]\n",
    "    print(f'  Fichiers BAAC : {len(baac_files)}')\n",
    "    for f in baac_files:\n",
    "        size = os.path.getsize(os.path.join(DATA_DIR, f)) / 1024 / 1024\n",
    "        print(f'    ✓ {f} ({size:.1f} Mo)')\n",
    "    print(f'  Autres CSV : {other_files}')\n",
    "except FileNotFoundError:\n",
    "    print(f'  ⚠️ Dossier non trouvé : {DATA_DIR}')\n",
    "    print('  → Créez le dossier et déposez-y vos fichiers BAAC depuis data.gouv.fr')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Étape 4 : Lancer Streamlit avec tunnel public ──────────────\n",
    "import subprocess, threading, time\n",
    "from pyngrok import ngrok\n",
    "\n",
    "# Config Streamlit\n",
    "os.makedirs('.streamlit', exist_ok=True)\n",
    "with open('.streamlit/config.toml', 'w') as f:\n",
    "    f.write('[server]\\nheadless = true\\nport = 8501\\nenableCORS = false\\n')\n",
    "\n",
    "# Lancer Streamlit en arrière-plan\n",
    "proc = subprocess.Popen(\n",
    "    ['streamlit', 'run', 'app.py', '--server.port=8501',\n",
    "     '--server.headless=true', '--server.enableCORS=false'],\n",
    "    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL\n",
    ")\n",
    "time.sleep(5)  # attendre le démarrage\n",
    "\n",
    "# Tunnel ngrok\n",
    "tunnel = ngrok.connect(8501)\n",
    "print('=' * 55)\n",
    "print('🚀  DASHBOARD ACCESSIBLE ICI :')\n",
    "print(f'    {tunnel.public_url}')\n",
    "print('=' * 55)\n",
    "print(f'\\n💡  Dans la barre latérale du dashboard,')\n",
    "print(f'    entrez le chemin des données :')\n",
    "print(f'    {DATA_DIR}')\n",
    "print('\\n    L\\'onglet \"Analyse BAAC 2018–2024\" sera')\n",
    "print('    automatiquement déverrouillé si les fichiers sont présents.')"
   ],
   "execution_count": null,
   "outputs": []
  },
