    "# ── Optionnel : Vérifier la structure des fichiers BAAC ────────\n",
    "import pandas as pd\n",
    "\n",
    "print('Vérification des fichiers BAAC :')\n",
    "checks = [\n",
    "    ('caract2024.csv',           'utf-8',      ';'),\n",
    "    ('caract2023.csv',           'utf-8',      ';'),\n",
    "    ('caract2022.csv',           'utf-8',      ';'),\n",
    "    ('carcteristiques2021.csv',  'utf-8',      ';'),\n",
    "    ('carcteristiques2022.csv',  'utf-8',      ';'),\n",
    "    ('caracteristiques2020.csv', 'utf-8',      ';'),\n",
    "    ('caracteristiques2019.csv', 'utf-8',      ';'),\n",
    "    ('caracteristiques2018.csv', 'iso-8859-1', ','),\n",
    "]\n",
    "for fname, enc, sep in checks:\n",
    "    fpath = os.path.join(DATA_DIR, fname)\n",
    "    if os.path.exists(fpath):\n",
    "        try:\n",
    "            df = pd.read_csv(fpath, sep=sep, encoding=enc, nrows=3)\n",
    "            print(f'  ✓ {fname} — {len(df.columns)} colonnes')\n",
    "        except Exception as e:\n",
    "            print(f'  ⚠️ {fname} — erreur lecture : {e}')\n",
    "    else:\n",
    "        print(f'  ✗ {fname} — MANQUANT')"
   ],
