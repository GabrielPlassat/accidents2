  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Étape 2 : Installer les dépendances ───────────────────────\n",
    "!pip install streamlit plotly pandas numpy scipy statsmodels pyngrok -q\n",
    "print('✓ Dépendances installées')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Étape 3 : Monter Google Drive (si données sur Drive) ───────\n",
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "# Chemin vers vos données CSV sur Drive\n",
    "# Exemple : /content/drive/MyDrive/AccidentsFrance/\n",
    "DATA_DIR = '/content/drive/MyDrive/AccidentsFrance/'  # ← Adaptez ce chemin\n",
    "print(f'Données depuis : {DATA_DIR}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Étape 4 : Lancer Streamlit avec tunnel public ──────────────\n",
    "import subprocess\n",
    "import threading\n",
    "import time\n",
    "from pyngrok import ngrok\n",
    "\n",
    "# Créer un fichier de config pour pointer vers les données\n",
    "import os\n",
    "config_content = f'''\n",
    "# Streamlit config\n",
    "[server]\n",
    "headless = true\n",
    "port = 8501\n",
    "'''\n",
    "os.makedirs('.streamlit', exist_ok=True)\n",
    "with open('.streamlit/config.toml', 'w') as f:\n",
    "    f.write(config_content)\n",
    "\n",
    "# Lancer Streamlit en arrière-plan\n",
    "def run_streamlit():\n",
    "    subprocess.run([\n",
    "        'streamlit', 'run', 'app.py',\n",
    "        '--server.port=8501',\n",
    "        '--server.headless=true',\n",
    "        '--server.enableCORS=false'\n",
    "    ])\n",
    "\n",
    "thread = threading.Thread(target=run_streamlit, daemon=True)\n",
    "thread.start()\n",
    "time.sleep(4)  # Attendre le démarrage\n",
    "\n",
    "# Créer le tunnel ngrok\n",
    "tunnel = ngrok.connect(8501)\n",
    "print(f'\\n🚀 Dashboard accessible ici :')\n",
    "print(f'   {tunnel.public_url}')\n",
    "print(f'\\n💡 Dans la barre latérale, entrez le chemin des données :')\n",
    "print(f'   {DATA_DIR}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Optionnel : Vérifier les fichiers disponibles ──────────────\n",
    "import os\n",
    "import pandas as pd\n",
    "\n",
    "print('Fichiers CSV trouvés :')\n",
    "for f in sorted(os.listdir(DATA_DIR)):\n",
    "    if f.endswith('.csv'):\n",
    "        size = os.path.getsize(os.path.join(DATA_DIR, f)) / 1024 / 1024\n",
    "        print(f'  ✓ {f} ({size:.1f} Mo)')"
